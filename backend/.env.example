# Server
PORT=3333
NODE_ENV=development
APP_NAME="FinSync"

# Database
DATABASE_URL="mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority"

# Auth
JWT_SECRET="replace-with-a-long-random-secret"
JWT_EXPIRES_IN="7d"

# CORS
FRONTEND_URL="http://localhost:5173"

# Open Finance / Pluggy
OPEN_FINANCE_PROVIDER="pluggy"
PLUGGY_CLIENT_ID="replace-with-pluggy-client-id"
PLUGGY_CLIENT_SECRET="replace-with-pluggy-client-secret"
PLUGGY_WEBHOOK_URL="https://api-finsync.paytech.app.br/api/open-finance/webhook"
PLUGGY_OAUTH_REDIRECT_URL="https://finsync.paytech.app.br/open-finance/connect"
